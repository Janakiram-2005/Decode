# Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this to .env (locally) or set directly in Render's Environment tab.
#
# Set this to your deployed backend URL (no trailing slash):
#   Local dev  → http://localhost:8000/api
#   Render     → https://ml-decode-backend.onrender.com/api
# ─────────────────────────────────────────────────────────────────────────────

VITE_API_URL=http://localhost:8000/api
