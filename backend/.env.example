# ─────────────────────────────────────────────────────────────────────────────
# Traceable Media Verification System — Backend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/
DB_NAME=media_verification_db

# JWT
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin registration gate
ADMIN_REGISTER=CHANGE_ME_strong_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AES-256 encryption key (64 hex chars = 32 bytes)
ENCRYPTION_KEY=CHANGE_ME_use_python_secrets_token_hex_32

# Allowed frontend origin (for CORS on Render)
# Example: https://your-frontend.onrender.com
FRONTEND_ORIGIN=http://localhost:5173
